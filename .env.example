# Database
DATABASE_URL="postgresql://mentorme:mentorme@localhost:5433/mentorme?schema=public"

# Auth (NextAuth v5)
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Site
PUBLIC_SITE_URL="http://localhost:3000"

# Media storage
UPLOAD_DIR="public/uploads"
STORAGE_PROVIDER="local" # local | s3 | r2 | supabase

# Scheduling integrations
CALENDLY_URL="https://calendly.com/mentorme"
CALCOM_URL="https://cal.com/mentorme"

# Observability
SENTRY_DSN=""
LOG_LEVEL="info"
