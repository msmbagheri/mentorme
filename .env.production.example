# MentorMe — PRODUCTION env template. Copy to .env.production and fill real values.
#   cp .env.production.example .env.production
# Generate secrets:
#   POSTGRES_PASSWORD:  openssl rand -hex 24
#   NEXTAUTH_SECRET:    openssl rand -base64 48

# --- Postgres (container) ---
POSTGRES_USER=mentorme
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=mentorme

# --- App: must match the Postgres creds above; host is the compose service name `db` ---
DATABASE_URL=postgresql://mentorme:change-me-strong-password@db:5432/mentorme?schema=public

# --- Auth (NextAuth v5) ---
NEXTAUTH_SECRET=change-me-long-random-string
NEXTAUTH_URL=https://mentorme.ir
AUTH_TRUST_HOST=true

# --- Site ---
PUBLIC_SITE_URL=https://mentorme.ir

# --- Media storage ---
UPLOAD_DIR=public/uploads
STORAGE_PROVIDER=local

# --- Scheduling integrations ---
CALENDLY_URL=https://calendly.com/mentorme
CALCOM_URL=https://cal.com/mentorme

# --- Observability ---
SENTRY_DSN=
LOG_LEVEL=info
